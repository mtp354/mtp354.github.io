---
layout: null
permalink: /quantum-radar.xml
---
<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom">
  <title>{{ site.title | xml_escape }} — Quantum Radar</title>
  <link href="{{ '/quantum-radar.xml' | absolute_url }}" rel="self" />
  <link href="{{ '/quantum-radar/' | absolute_url }}" />
  <updated>{{ site.time | date_to_xmlschema }}</updated>
  <id>{{ '/quantum-radar.xml' | absolute_url }}</id>
  {% assign entries = site.quantum_radar | sort: "date" | reverse %}
  {% for e in entries limit: 30 %}
  <entry>
    <title>{{ e.title | strip_html | xml_escape }}</title>
    <link href="{{ e.url | absolute_url }}" />
    <id>{{ e.url | absolute_url }}</id>
    {% if e.date %}<updated>{{ e.date | date_to_xmlschema }}</updated>{% endif %}
    {% if e.excerpt %}<summary>{{ e.excerpt | strip_html | xml_escape }}</summary>{% endif %}
    {% if e.report_type %}<category term="{{ e.report_type }}" />{% endif %}
  </entry>
  {% endfor %}
</feed>
