source 'https://rubygems.org'

# `github-pages` already pins jekyll, jekyll-feed, jekyll-sitemap,
# jekyll-redirect-from, and jemoji, so we do not list them here.
gem 'github-pages', group: :jekyll_plugins

# Required for `bundle exec jekyll serve` on Ruby 3.x during local dev.
gem 'webrick', '~> 1.8', group: :jekyll_plugins
